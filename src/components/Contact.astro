---
---
<section id="contact" class="contact py-20 bg-honey-bg">
  <div class="container mx-auto w-full max-w-[1100px] px-5">
    <h2 class="text-3xl font-bold text-honey-text mb-8">Contact</h2>

    <form id="contact-form" novalidate class="max-w-lg flex flex-col gap-5 mb-10">
      <div class="form-group flex flex-col gap-1">
        <label for="name" class="font-semibold text-honey-text">Name</label>
        <input type="text" id="name" name="name" required autocomplete="name"
          class="border border-gray-200 rounded-xl px-4 py-3 text-honey-text bg-honey-surface focus:outline-none focus:border-honey-accent transition-colors" />
      </div>

      <div class="form-group flex flex-col gap-1">
        <label for="email" class="font-semibold text-honey-text">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="border border-gray-200 rounded-xl px-4 py-3 text-honey-text bg-honey-surface focus:outline-none focus:border-honey-accent transition-colors" />
      </div>

      <div class="form-group flex flex-col gap-1">
        <label for="message" class="font-semibold text-honey-text">Message</label>
        <textarea id="message" name="message" rows="5" required
          class="border border-gray-200 rounded-xl px-4 py-3 text-honey-text bg-honey-surface focus:outline-none focus:border-honey-accent transition-colors resize-y"></textarea>
      </div>

      <button type="submit" class="btn btn-primary self-start inline-block px-6 py-3 rounded-xl font-semibold bg-honey-accent text-white hover:bg-honey-accent-dark transition-colors duration-200 cursor-pointer border-none">
        Send Message
      </button>
      <p class="form-status" role="status" aria-live="polite"></p>
    </form>

    <div class="contact__social">
      <p class="mb-3">
        <a href="mailto:reinvesting1012026@gmail.com" class="text-honey-accent hover:text-honey-accent-dark font-semibold">reinvesting1012026@gmail.com</a>
      </p>
      <ul class="social-links list-none m-0 p-0 flex gap-4">
        <li><a href="#" class="text-honey-muted hover:text-honey-accent transition-colors">GitHub</a></li>
        <li><a href="#" class="text-honey-muted hover:text-honey-accent transition-colors">LinkedIn</a></li>
        <li><a href="#" class="text-honey-muted hover:text-honey-accent transition-colors">Twitter / X</a></li>
      </ul>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.querySelector<HTMLElement>('.form-status');

  function setStatus(message: string, type: 'success' | 'error') {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.classList.remove('success', 'error');
    statusEl.classList.add(type);
  }

  if (form && statusEl) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const nameVal = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const emailVal = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const messageVal = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

      if (!nameVal) {
        setStatus('Please enter your name.', 'error');
        (form.elements.namedItem('name') as HTMLInputElement).focus();
        return;
      }

      if (!emailVal) {
        setStatus('Please enter your email address.', 'error');
        (form.elements.namedItem('email') as HTMLInputElement).focus();
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(emailVal)) {
        setStatus('Please enter a valid email address (e.g. you@example.com).', 'error');
        (form.elements.namedItem('email') as HTMLInputElement).focus();
        return;
      }

      if (!messageVal) {
        setStatus('Please enter a message.', 'error');
        (form.elements.namedItem('message') as HTMLTextAreaElement).focus();
        return;
      }

      setStatus('Thanks! Your message has been received.', 'success');
      form.reset();
    });
  }
</script>
