---
<section id="home" class="hero min-h-screen flex items-center justify-center" style="background: linear-gradient(135deg, #fffdf7 0%, #fef3c7 50%, #fde68a 100%);">
  <div class="hero__inner container mx-auto w-full max-w-[1100px] px-5 text-center">
    <h1 class="text-4xl md:text-6xl font-bold text-honey-text mb-4">Your Name</h1>
    <p class="hero-subtitle text-xl md:text-2xl text-honey-muted mb-8">Web Developer &amp; Designer</p>
    <div class="hero__cta flex gap-4 justify-center flex-wrap">
      <a
        href="#projects"
        class="btn btn-primary inline-block px-6 py-3 rounded-xl font-semibold bg-honey-accent text-white hover:bg-honey-accent-dark transition-colors duration-200 no-underline"
      >View My Work</a>
      <a
        href="#contact"
        class="btn btn-secondary inline-block px-6 py-3 rounded-xl font-semibold border-2 border-honey-accent text-honey-accent hover:bg-honey-accent hover:text-white transition-colors duration-200 no-underline"
      >Contact Me</a>
    </div>
  </div>
</section>
